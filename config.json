{
  "backend": "127.0.0.1:9502",
  "redis": {
    "addr": "127.0.0.1:6379",
    "db": 14,
    "password": ""
  },
  "rateLimit": {
    "maxRequests": 60,
    "globalMaxRequests": 2500,
    "windowSec": 10,
    "maxConn": 2
  },
  "auth": {
    "token": "CHANGE_ME_STRONG_TOKEN",
    "adminToken": "CHANGE_ME_ADMIN_TOKEN"
  },
  "trustedProxies": [
    "127.0.0.1/8",
    "::1/128"
  ],
  "enableWebSocket": true,
  "limits": {
    "maxConnections": 2000,
    "maxBodySizeMB": 2,
    "webSocketBufferSize": 262144,
    "webSocketMaxLifetimeSec": 7200,
    "ipsetConcurrency": 20,
    "ipsetTimeoutSec": 3,
    "machineHealthCheckSec": 2,
    "machineMaxCPUPercent": 100,
    "machineMaxLoadPerCpu": 2,
    "machineMaxMemoryPercent": 100,
    "machineUnhealthyThreshold": 3,
    "machineRecoveryThreshold": 3,
    "authTimeoutSec": 3,
    "shutdownTimeoutSec": 15
  }
}
